+      row.tradeVolume,
+      row.shareVolume,
+      row.turnover ?? null,
+      row.changeAmount,
+      row.changePercent,
+      row.isWatchList,
+      marketTimestamp ?? null,
+      sourceMarketTimestampText ?? null,
+      runId,
