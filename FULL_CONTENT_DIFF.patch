+     ON CONFLICT (symbol, trading_date)
+     DO UPDATE SET
+       security_id = EXCLUDED.security_id,
+       last_traded_price = EXCLUDED.last_traded_price,
+       previous_close = EXCLUDED.previous_close,
+       open_price = EXCLUDED.open_price,
