-+def _expand_cells(cells: list[Tag]) -> list[str]:
-+    expanded: list[str] = []
-+    for cell in cells:
-+        value = cell_text(cell)
-+        colspan = 1
-+        try:
-+            colspan = max(1, int(cell.get("colspan") or 1))
-+        except ValueError:
-+            colspan = 1
-+        expanded.extend([value] * colspan)
-+    return expanded
