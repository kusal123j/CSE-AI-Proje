+    logger.info('CSE Daily Market Summary scheduler disabled');
+    return null;
+  }
+
+  let running = false;
+  let lastRunKey = '';
+
+  const interval = setInterval(() => {
+    const now = new Date();
+    const runKey = now.toISOString().slice(0, 16);
+    if (!shouldRunDailyMarketSummaryNow(now) || running || lastRunKey === runKey) return;
+
+    running = true;
+    lastRunKey = runKey;
+    cseService
