+export async function fetchDailyMarketSummary(options: FetchAlphabeticalRowsOptions): Promise<FetchDailyMarketSummaryResult> {
+  assertDailyMarketSummarySourceUrl(env.CSE_DAILY_MARKET_SUMMARY_SOURCE_URL);
