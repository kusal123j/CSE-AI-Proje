+       last_seen_at = NOW(),
+       is_active = true,
+       raw_row = EXCLUDED.raw_row
+     RETURNING *, (xmax = 0) AS inserted`,
+    [row.industryGroupCode, row.gicsCode, row.symbol, row.industryGroupName, sourceUrl, JSON.stringify(row.rawRow)]
+  );
+  return result.rows[0];
