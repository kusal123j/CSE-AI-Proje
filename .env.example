# -------------------------
# CSE Research Engine Foundation v1.1 Corrected
# -------------------------
NODE_ENV=development
PORT=5000
LOG_LEVEL=debug
RUN_MIGRATIONS_ON_START=true

# PostgreSQL
DATABASE_URL=postgresql://cse_user:cse_password@postgres:5432/cse_research
POSTGRES_USER=cse_user
POSTGRES_PASSWORD=cse_password
POSTGRES_DB=cse_research

# Redis / BullMQ
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# MinIO / S3-compatible storage
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cse-documents
MINIO_USE_SSL=false

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=cse_document_chunks
QDRANT_VECTOR_SIZE=1536

# Python worker
PYTHON_WORKER_URL=http://python-worker:8000
PYTHON_WORKER_PORT=8000

# AI / LangChain placeholders
AI_PROVIDER=
AI_API_KEY=
EMBEDDING_MODEL=
CHAT_MODEL=

# Development-only collector flag. Real CSE client implementation comes later.
CSE_MOCK_MODE=false

# PDF download safety
MAX_PDF_SIZE_MB=100
PDF_DOWNLOAD_TIMEOUT_MS=60000


# CSE ALPHABETICAL Python HTTP importer / market snapshots
# Final rule: lightweight HTTP/API/export importer only; no Playwright/Chromium browser automation.
CSE_IMPORT_MODE=python-http
CSE_IMPORT_SOURCE_URL=https://www.cse.lk/listed-entities/listed-company-directory?page=ALPHABETICAL
CSE_LISTED_COMPANY_DIRECTORY_URL=https://www.cse.lk/listed-entities/listed-company-directory?page=ALPHABETICAL
CSE_IMPORT_FETCH_MODE=python-http
CSE_IMPORT_RAW_STORAGE_DIR=storage/raw/cse/alphabetical
CSE_IMPORT_ARTIFACT_STORAGE_DIR=storage/raw/cse/alphabetical
CSE_IMPORT_MIN_EXPECTED_ROWS=250
CSE_IMPORT_MIN_COMPANIES=280
CSE_IMPORT_MIN_SECURITIES=280
CSE_IMPORT_TIMEOUT_SECONDS=30
CSE_IMPORT_JOB_TIMEOUT_SECONDS=300
CSE_IMPORT_LETTER_TIMEOUT_SECONDS=30
CSE_IMPORT_MAX_RETRIES=3
CSE_IMPORT_RETRY_COUNT=3
CSE_IMPORT_STALE_AFTER_HOURS=36
CSE_IMPORT_USER_AGENT=Mozilla/5.0 compatible CSE Research Assistant Importer
# Set this before using POST /api/cse/import/alphabetical/run.
CSE_IMPORT_INTERNAL_SECRET=change-this-long-random-secret
CSE_IMPORT_ALLOW_UNPROTECTED_MANUAL_RUN=false
CSE_IMPORT_SCHEDULER_ENABLED=false
CSE_IMPORT_HOUR=16
CSE_IMPORT_MINUTE=0
CSE_IMPORT_WEEKDAYS_ONLY=true
CSE_IMPORT_SCHEDULER_INTERVAL_MS=60000

# CSE Trade Summary daily market statistics importer
# Final rule: separate daily market snapshot source; HTTP/API first, optional CSV fallback, no browser automation.
CSE_TRADE_SUMMARY_ENABLED=true
CSE_TRADE_SUMMARY_SOURCE_URL=https://www.cse.lk/equity/trade-summary
CSE_TRADE_SUMMARY_CSV_URL=
CSE_TRADE_SUMMARY_ARTIFACT_STORAGE_DIR=storage/raw/cse/trade-summary
CSE_TRADE_SUMMARY_MIN_EXPECTED_ROWS=100
CSE_TRADE_SUMMARY_TIMEOUT_SECONDS=90
CSE_TRADE_SUMMARY_SCHEDULER_ENABLED=false
CSE_TRADE_SUMMARY_HOUR=15
CSE_TRADE_SUMMARY_MINUTE=45
CSE_TRADE_SUMMARY_WEEKDAYS_ONLY=true

# CSE GICS industry intelligence import (manual first; no browser automation)
CSE_GICS_ENABLED=true
CSE_GICS_SUMMARY_SOURCE_URL=https://www.cse.lk/equity/gics-industry-group-summary
CSE_GICS_INDICES_SOURCE_URL=https://www.cse.lk/equity/gics-industry-group-indices
CSE_GICS_CLASSIFICATION_SOURCE_URL=https://www.cse.lk/listed-entities/gics-classification
CSE_GICS_ARTIFACT_STORAGE_DIR=storage/raw/cse/gics
CSE_GICS_MIN_EXPECTED_GROUPS=20
CSE_GICS_MIN_EXPECTED_CLASSIFICATION_ROWS=250
CSE_GICS_TIMEOUT_SECONDS=120
CSE_GICS_SCHEDULER_ENABLED=false

# CSE Daily Market Summary importer (market-level aggregate snapshot)
CSE_DAILY_MARKET_SUMMARY_ENABLED=true
CSE_DAILY_MARKET_SUMMARY_SOURCE_URL=https://www.cse.lk/equity/daily-market-summary
CSE_DAILY_MARKET_SUMMARY_ARTIFACT_STORAGE_DIR=storage/raw/cse/daily-market-summary
CSE_DAILY_MARKET_SUMMARY_TIMEOUT_SECONDS=90
CSE_DAILY_MARKET_SUMMARY_SCHEDULER_ENABLED=false
CSE_DAILY_MARKET_SUMMARY_HOUR=16
CSE_DAILY_MARKET_SUMMARY_MINUTE=15
CSE_DAILY_MARKET_SUMMARY_WEEKDAYS_ONLY=true

# CSE Company Intelligence importers (no Playwright/Chromium)
CSE_COMPANY_PROFILE_ENABLED=true
CSE_COMPANY_PROFILE_SOURCE_URL=https://www.cse.lk/company-profile
CSE_COMPANY_PROFILE_API_URL=https://www.cse.lk/api/companyInfoSummery
CSE_COMPANY_PROFILE_TIMEOUT_SECONDS=90
CSE_COMPANY_PROFILE_SCHEDULER_ENABLED=false
CSE_COMPANY_PROFILE_REFRESH_HOURS=6

CSE_COMPANY_FINANCIAL_REPORTS_ENABLED=true
CSE_COMPANY_FINANCIAL_REPORTS_API_URL=https://www.cse.lk/api/getFinancialAnnouncement
CSE_COMPANY_FINANCIAL_REPORTS_TIMEOUT_SECONDS=120
CSE_COMPANY_FINANCIAL_REPORTS_SCHEDULER_ENABLED=false
CSE_COMPANY_FINANCIAL_REPORTS_HOUR=18
CSE_COMPANY_FINANCIAL_REPORTS_MINUTE=0
CSE_COMPANY_FINANCIAL_REPORTS_WEEKDAYS_ONLY=true

CSE_COMPANY_ANNOUNCEMENTS_ENABLED=true
CSE_COMPANY_ANNOUNCEMENTS_API_URL=https://www.cse.lk/api/approvedAnnouncement
CSE_COMPANY_ANNOUNCEMENTS_TIMEOUT_SECONDS=120
CSE_COMPANY_ANNOUNCEMENTS_SCHEDULER_ENABLED=false
CSE_COMPANY_ANNOUNCEMENTS_HOUR=18
CSE_COMPANY_ANNOUNCEMENTS_MINUTE=30
CSE_COMPANY_ANNOUNCEMENTS_WEEKDAYS_ONLY=true
CSE_COMPANY_ANNOUNCEMENTS_LOOKBACK_DAYS=7

CSE_LATEST_PRICE_POLLER_ENABLED=false
CSE_LATEST_PRICE_API_URL=https://www.cse.lk/api/todaySharePrice
CSE_MARKET_STATUS_API_URL=https://www.cse.lk/api/marketStatus
CSE_LATEST_PRICE_TIMEOUT_SECONDS=60
CSE_LATEST_PRICE_POLL_INTERVAL_MS=180000
CSE_LATEST_PRICE_WEEKDAYS_ONLY=true
CSE_MARKET_OPEN_TIME=10:30
CSE_MARKET_CLOSE_TIME=14:30
